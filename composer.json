{
  "name": "neo4j-php/neo4j-laravel",
  "description": "A Laravel package for Neo4j integration",
  "version": "1.0.0",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Neo4jPhp\\Neo4jLaravel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Neo4jPhp\\Neo4jLaravel\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "illuminate/support": "^11.0",
    "laudis/neo4j-php-client": "^3.2",
    "guzzlehttp/guzzle": "^7.9"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0",
    "phpunit/phpunit": "^11.0",
    "vimeo/psalm": "^6.8",
    "psalm/plugin-laravel": "^2.12",
    "friendsofphp/php-cs-fixer": "^3.69"
  },
  "scripts": {
    "psalm": "vendor/bin/psalm",
    "psalm:fix": "vendor/bin/psalm --alter --issues=all",
    "cs": "vendor/bin/php-cs-fixer fix -v --dry-run",
    "cs:fix": "vendor/bin/php-cs-fixer fix -v",
    "analyse": [
      "@psalm",
      "@cs"
    ],
    "fix": [
      "@psalm:fix",
      "@cs:fix"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Neo4jPhp\\Neo4jLaravel\\Neo4jServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
